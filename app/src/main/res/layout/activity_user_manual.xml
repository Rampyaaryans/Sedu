<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Back"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/primary_dark" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SEDU"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.08" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User Guide"
                    android:textSize="14sp"
                    android:textColor="@color/text_light"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="1dp" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/primary"
            android:alpha="0.5"
            android:layout_marginBottom="20dp" />

        <!-- Section 1: Getting Started -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="14dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_rocket"
                    android:contentDescription="Getting Started"
                    app:tint="@color/primary_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Getting Started"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Train Your Voice — Tap 'Train My Voice' and say 'SEDU' 5 times. This ensures ONLY your voice activates Sedu.\n\n2. Start Sedu — Tap 'Start' button. Sedu will listen for your wake word in the background.\n\n3. Say 'SEDU' — When you need help, just say 'Sedu' clearly. The screen will glow green and vibrate.\n\n4. Give Your Command — Speak naturally in Hindi, English, or Hinglish. Sedu understands all three!"
                android:textSize="14sp"
                android:textColor="@color/text_light"
                android:lineSpacingMultiplier="1.35" />
        </LinearLayout>

        <!-- Section 2: Phone Calls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="14dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_phone"
                    android:contentDescription="Phone Calls"
                    app:tint="@color/primary_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone Calls"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Top Priority"
                    android:textSize="11sp"
                    android:textColor="@color/primary_dark"
                    android:fontFamily="sans-serif-medium"
                    android:background="@color/primary"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• 'Sedu, call Mama' — Calls Mama directly\n• 'Sedu, call Aru Papa' — Calls the exact contact\n• 'Sedu, call Papa' — If multiple Papas exist, Sedu will ASK which one\n• 'Sedu, Papa ko call karo' — Hindi works too!\n\nSmart Contact Matching: Sedu knows all your contacts. If a name is ambiguous, it asks to clarify."
                android:textSize="14sp"
                android:textColor="@color/text_light"
                android:lineSpacingMultiplier="1.35" />
        </LinearLayout>

        <!-- Section 3: Messages -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="14dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_chat"
                    android:contentDescription="Messages"
                    app:tint="@color/primary_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Messages"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• 'Sedu, SMS Mama — I'll be late' — Opens SMS with message\n• 'Sedu, WhatsApp Rahul — meeting at 5' — Sends WhatsApp\n• Works with Hindi: 'Sedu, Rahul ko WhatsApp karo — kal milte hain'"
                android:textSize="14sp"
                android:textColor="@color/text_light"
                android:lineSpacingMultiplier="1.35" />
        </LinearLayout>

        <!-- Section 4: Web Search -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="14dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_search"
                    android:contentDescription="Web Search"
                    app:tint="@color/primary_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Web Search"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• 'Sedu, search iPhone 16 price' — Opens Google search\n• 'Sedu, Google best restaurants near me' — Web search\n• 'Sedu, search karo weather today' — Hindi search too"
                android:textSize="14sp"
                android:textColor="@color/text_light"
                android:lineSpacingMultiplier="1.35" />
        </LinearLayout>

        <!-- Section 5: Music -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="14dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_music"
                    android:contentDescription="Music"
                    app:tint="@color/primary_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Music"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• 'Sedu, play Arijit Singh' — Plays Arijit Singh songs\n• 'Sedu, play Tum Hi Ho' — Plays specific song\n• 'Sedu, kuch sunao' — Sedu ASKS what you want to hear\n• 'Sedu, play some music' — Sedu asks your preference\n\nWorks with: YouTube Music, Spotify, JioSaavn, Gaana, and more!"
                android:textSize="14sp"
                android:textColor="@color/text_light"
                android:lineSpacingMultiplier="1.35" />
        </LinearLayout>

        <!-- Section 6: Chat & Questions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="14dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_brain"
                    android:contentDescription="Chat and Questions"
                    app:tint="@color/primary_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chat &amp; Questions"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• 'Sedu, kya haal hai?' — Friendly conversation\n• 'Sedu, what is AI?' — Explains AI in Hinglish\n• 'Sedu, tell me a joke' — Tells a joke!\n• 'Sedu, 2 plus 2?' — Quick math\n• 'Sedu, India ka capital?' — General knowledge\n• 'Sedu, mujhe motivate karo' — Motivational talk\n\nSedu is your personal Jarvis — ask ANYTHING!"
                android:textSize="14sp"
                android:textColor="@color/text_light"
                android:lineSpacingMultiplier="1.35" />
        </LinearLayout>

        <!-- Section 7: Device Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="14dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_settings"
                    android:contentDescription="Device Controls"
                    app:tint="@color/primary_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Device Controls"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Volume:\n• 'Sedu, volume up' / 'volume down' / 'mute'\n\nFlashlight:\n• 'Sedu, torch on' / 'torch off'\n\nBrightness:\n• 'Sedu, brightness up' / 'brightness down'\n\nConnectivity:\n• 'Sedu, WiFi on' / 'WiFi off'\n• 'Sedu, Bluetooth on' / 'Bluetooth off'\n\nSettings:\n• 'Sedu, open WiFi settings' / 'open display settings'"
                android:textSize="14sp"
                android:textColor="@color/text_light"
                android:lineSpacingMultiplier="1.35" />
        </LinearLayout>

        <!-- Section 8: Time, Alarms & Timers -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="14dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_clock"
                    android:contentDescription="Time Alarms Timers"
                    app:tint="@color/primary_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Time, Alarms &amp; Timers"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• 'Sedu, what time is it?' — Tells current time\n• 'Sedu, aaj kya date hai?' — Tells date\n• 'Sedu, set alarm 7:30 AM' — Sets alarm\n• 'Sedu, set timer 5 minutes' — Starts countdown\n• 'Sedu, battery kitni hai?' — Battery level"
                android:textSize="14sp"
                android:textColor="@color/text_light"
                android:lineSpacingMultiplier="1.35" />
        </LinearLayout>

        <!-- Section 9: Navigation & Apps -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="14dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_navigation"
                    android:contentDescription="Navigation and Apps"
                    app:tint="@color/primary_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Navigation &amp; Apps"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• 'Sedu, navigate to Jaipur' — Opens Google Maps\n• 'Sedu, open Instagram' — Launches app\n• 'Sedu, open camera' — Opens camera\n• 'Sedu, open YouTube' — Opens any installed app"
                android:textSize="14sp"
                android:textColor="@color/text_light"
                android:lineSpacingMultiplier="1.35" />
        </LinearLayout>

        <!-- Section 10: Screen Reading -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="14dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_screen"
                    android:contentDescription="Screen Reading"
                    app:tint="@color/primary_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Screen Reading"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• 'Sedu, read screen' — Reads what's on your screen aloud\n• 'Sedu, screen pe kya hai?' — Describes screen content\n\nRequires Accessibility Service to be enabled in Settings."
                android:textSize="14sp"
                android:textColor="@color/text_light"
                android:lineSpacingMultiplier="1.35" />
        </LinearLayout>

        <!-- Section 11: Pro Tips -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="14dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_lightbulb"
                    android:contentDescription="Pro Tips"
                    app:tint="@color/primary_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pro Tips"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Speak clearly — Sedu works best within 1-2 meters\n• Wait for the green glow before speaking your command\n• You can interrupt Sedu mid-response — just start speaking\n• Say 'bye' or 'goodbye' to end conversation\n• Sedu stays active for 45 seconds between commands\n• Re-train your voice if others can activate Sedu\n• Sedu works offline for wake word, needs internet for commands\n• Speak naturally — Hindi, English, or mixed!"
                android:textSize="14sp"
                android:textColor="@color/text_light"
                android:lineSpacingMultiplier="1.35" />
        </LinearLayout>

        <!-- Section 12: Stopping Sedu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="14dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_stop"
                    android:contentDescription="Stopping Sedu"
                    app:tint="@color/primary_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stopping Sedu"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Tap 'Stop' in app — Sedu goes to sleep mode (still listens for wake word)\n• Say 'Sedu, goodbye' — Ends current conversation\n• Sedu auto-sleeps after 45 seconds of no commands\n• Force stop from Android Settings to fully stop"
                android:textSize="14sp"
                android:textColor="@color/text_light"
                android:lineSpacingMultiplier="1.35" />
        </LinearLayout>

        <!-- Footer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/primary"
            android:alpha="0.3"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SEDU v2.0 — Your Personal AI Voice Agent"
            android:textSize="12sp"
            android:textColor="@color/text_light"
            android:gravity="center"
            android:fontFamily="sans-serif"
            android:alpha="0.7"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
