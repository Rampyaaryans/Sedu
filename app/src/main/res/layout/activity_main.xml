<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Animated gradient background -->
    <View
        android:id="@+id/animatedBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Edge glow -->
    <View
        android:id="@+id/edgeGlow"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <!-- Top spacer to push title to ~30% -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1.8" />

        <!-- SEDU animated title (large hero text) -->
        <LinearLayout
            android:id="@+id/titleContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/letterS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S"
                android:textSize="80sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:alpha="0"
                android:letterSpacing="0.12"
                android:shadowColor="#4DA8E6CF"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="16"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/letterE"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="E"
                android:textSize="80sp"
                android:textStyle="bold"
                android:textColor="@color/primary_dark"
                android:alpha="0"
                android:letterSpacing="0.12"
                android:shadowColor="#4DA8E6CF"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="16"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/letterD"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="D"
                android:textSize="80sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:alpha="0"
                android:letterSpacing="0.12"
                android:shadowColor="#4DA8E6CF"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="16"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/letterU"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="U"
                android:textSize="80sp"
                android:textStyle="bold"
                android:textColor="@color/primary_dark"
                android:alpha="0"
                android:letterSpacing="0.12"
                android:shadowColor="#4DA8E6CF"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="16"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Your Personal Voice Agent"
            android:textColor="@color/text_light"
            android:textSize="15sp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.1"
            android:alpha="0" />

        <!-- Status pill -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Say 'Sedu' to activate"
            android:textColor="@color/text_dark"
            android:textSize="16sp"
            android:fontFamily="sans-serif"
            android:background="@drawable/status_pill_bg"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:alpha="0" />

        <!-- Middle spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="2.2" />

        <!-- Bottom action area with card background -->
        <LinearLayout
            android:id="@+id/bottomCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/bottom_card_bg"
            android:paddingTop="28dp"
            android:paddingBottom="32dp"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:elevation="8dp">

            <!-- Primary action: Start/Stop -->
            <Button
                android:id="@+id/toggleButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/primary_dark"
                android:text="Start Sedu"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                android:elevation="4dp"
                android:stateListAnimator="@null"
                android:alpha="0" />

            <!-- Secondary actions row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <Button
                    android:id="@+id/trainVoiceButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="@color/primary"
                    android:text="Train Voice"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:elevation="2dp"
                    android:stateListAnimator="@null"
                    android:alpha="0" />

                <Button
                    android:id="@+id/historyButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:backgroundTint="@color/primary"
                    android:text="History"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:elevation="2dp"
                    android:stateListAnimator="@null"
                    android:alpha="0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <Button
                    android:id="@+id/voiceSettingsButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:backgroundTint="@color/primary"
                    android:text="Voice"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:elevation="2dp"
                    android:stateListAnimator="@null"
                    android:alpha="0" />

                <Button
                    android:id="@+id/apiKeysButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:backgroundTint="@color/primary"
                    android:text="API Keys"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:elevation="2dp"
                    android:stateListAnimator="@null"
                    android:alpha="0" />
            </LinearLayout>

            <!-- How to use link -->
            <TextView
                android:id="@+id/userManualButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How to Use Sedu"
                android:textColor="@color/text_light"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:paddingTop="8dp"
                android:paddingBottom="4dp"
                android:clickable="true"
                android:focusable="true"
                android:alpha="0" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
