<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Animated gradient background view (programmatic) -->
    <View
        android:id="@+id/animatedBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Screen edge glow -->
    <View
        android:id="@+id/edgeGlow"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- SEDU animated title -->
        <LinearLayout
            android:id="@+id/titleContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/letterS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S"
                android:textSize="72sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:alpha="0"
                android:letterSpacing="0.15"
                android:shadowColor="#4DA8E6CF"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="12"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/letterE"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="E"
                android:textSize="72sp"
                android:textStyle="bold"
                android:textColor="@color/primary_dark"
                android:alpha="0"
                android:letterSpacing="0.15"
                android:shadowColor="#4DA8E6CF"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="12"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/letterD"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="D"
                android:textSize="72sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:alpha="0"
                android:letterSpacing="0.15"
                android:shadowColor="#4DA8E6CF"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="12"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/letterU"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="U"
                android:textSize="72sp"
                android:textStyle="bold"
                android:textColor="@color/primary_dark"
                android:alpha="0"
                android:letterSpacing="0.15"
                android:shadowColor="#4DA8E6CF"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="12"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Voice Agent"
            android:textColor="@color/text_light"
            android:textSize="16sp"
            android:alpha="0" />

        <!-- Status -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="Say Sedu to activate"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:alpha="0" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Toggle button - minimal -->
        <Button
            android:id="@+id/toggleButton"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="@color/primary"
            android:text="Start"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            android:alpha="0" />

        <!-- Train Voice button -->
        <Button
            android:id="@+id/trainVoiceButton"
            android:layout_width="200dp"
            android:layout_height="44dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="@color/primary_dark"
            android:text="Train My Voice"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:alpha="0" />

        <!-- View History button -->
        <Button
            android:id="@+id/historyButton"
            android:layout_width="200dp"
            android:layout_height="44dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#5B6ABF"
            android:text="View History"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:alpha="0" />

        <!-- User Manual button -->
        <Button
            android:id="@+id/userManualButton"
            android:layout_width="200dp"
            android:layout_height="44dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="@color/text_light"
            android:text="How to Use Sedu"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:alpha="0" />

    </LinearLayout>

</FrameLayout>
